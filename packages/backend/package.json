{
  "name": "@ecommerce-mvp/backend",
  "version": "1.0.0",
  "description": "Backend API server for e-commerce platform",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "start": "bun run dist/index.js",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "elysia": "^1.0.0",
    "@elysiajs/cors": "^1.0.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0",
    "jose": "^5.2.0",
    "bcrypt": "^5.1.1",
    "zod": "^3.22.0",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "@types/bcrypt": "^5.0.2",
    "drizzle-kit": "^0.20.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  }
}
